# Server
PORT=3456

# JWT
JWT_SECRET=change-me-to-a-random-string

# Admin credentials (used on first run to create admin user)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me

# Data source paths (local)
CLAUDE_PROJECTS_PATH=~/.claude/projects
CODEX_SESSIONS_PATH=~/.codex/sessions

# OpenAI API (optional, for API key usage tracking)
OPENAI_API_KEY=
OPENAI_ORG_ID=

# Sync interval (cron expression, default every 10 min)
SYNC_CRON=*/10 * * * *
